{
    "name": "edhrendal/phpstan-edhrendal",
    "description": "PHPStan custom rules for Edhrendal projects",
    "license": "MIT",
    "type": "phpstan-extension",
    "authors": [
        {
            "name": "Billy VILLENA",
            "email": "1339642+Edhrendal@users.noreply.github.com"
        }
    ],
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "phpstan/phpstan": "~2.1.0"
    },
    "require-dev": {
        "phpstan/phpstan-phpunit": "~2.0.0",
        "phpunit/phpunit": "~11.5.0"
    },
    "autoload": {
        "psr-4": {
            "Edhrendal\\PHPStan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Edhrendal\\PHPStan\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Rules/data/"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    }
}
